    "override_android_vpn": true,
    "default_domain_resolver": "dns-remote",
    "final": "select",
    "rules": [
      {
        "action": "sniff"
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "domain": [
          "connectivitycheck.gstatic.com",
          "connectivitycheck.android.com"
        ],
        "outbound": "direct"
      }
    ]
  },
  "experimental": {
    "cache_file": {
      "enabled": true
    }
  }
}
